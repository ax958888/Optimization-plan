# Alkaid Self-Optimization System v2
# CPX31 integrated configuration

# ── Paths ──
KIRO_PATH=/root/.kiro
MEMORY_PATH=/root/.kiro/memory/conversations.jsonl
LEARNING_PATH=/root/.kiro/learning
LEARNINGS_PATH=/root/.kiro/.learnings
KANBAN_DB_PATH=/root/kanban-kiro-bot/data/kanban.db
INSIGHTS_DB_PATH=/root/.kiro/learning/insights.db

# ── Discord (already configured in Bot .env files) ──
ALKAID_CHANNEL_ID=1484560345405063289
ARCHIVE_CHANNEL_ID=1484434683528744980
ALKAID_BOT_ID=1484557430443610163
KANBAN_BOT_ID=1484372402078093352

# ── GitHub ──
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=ax958888/VPS-Kanban-Agent

# ── QMD ──
QMD_BINARY=/usr/bin/qmd
QMD_COLLECTION=alkaid
QMD_DEDUP_THRESHOLD=0.85

# ── Kiro CLI ──
KIRO_CLI_PATH=/root/.local/bin/kiro-cli
KIRO_AGENT=alkaid
KIRO_TIMEOUT=300

# ── Schedule ──
DAILY_ANALYSIS_HOUR=23
DAILY_ANALYSIS_MINUTE=30
WEEKLY_REPORT_DAY=6
PROMPT_OPTIMIZE_THRESHOLD=5

# ── Limits ──
MAX_TASKS_PER_ANALYSIS=50
MAX_CONVERSATIONS_PER_ANALYSIS=100
MAX_DAILY_DIGEST_RETENTION_DAYS=30
